package templates

templ PostList(v PostListView) {
	@Layout(docTitle(v.Heading), "/posts") {
		<h1>{ v.Heading }</h1>
		if len(v.Posts) > 0 {
			<ul>
				for _, p := range v.Posts {
					<li>
						<a href={ p.URL + "/" }>{ p.Title }</a> —
						{ fmtDate(p.PublishedAt) }
						if p.Headline != "" {
							— { p.Headline }
						}
					</li>
				}
			</ul>
		} else {
			<p>Nothing here yet.</p>
		}
	}
}
